{
	"name": "state-resource",
	"version": "0.3.0",
	"type": "module",
	"description": "Async state resource management",
	"main": "./dist/state-resource.cjs",
	"module": "./dist/state-resource.mjs",
	"browser": "./dist/state-resource.umd.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/state-resource.mjs",
			"require": "./dist/state-resource.cjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown && tsc --emitDeclarationOnly",
		"dev": "tsdown --watch",
		"build:types": "tsc --emitDeclarationOnly",
		"clean": "rm -rf dist *.tsbuildinfo",
		"test": "vitest run --coverage",
		"test:watch": "vitest --watch --coverage",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix"
	},
	"author": "Danilo Castro",
	"license": "MIT",
	"devDependencies": {
		"@eslint/css": "^1.2.0",
		"@eslint/js": "^10.0.1",
		"@eslint/json": "^1.2.0",
		"@eslint/markdown": "^8.0.2",
		"@types/node": "^25.9.1",
		"@types/react": "^19.2.15",
		"@vitest/coverage-v8": "4.1.7",
		"eslint": "^10.4.0",
		"eslint-plugin-react-hooks": "^7.1.1",
		"globals": "^17.6.0",
		"jsdom": "^29.1.1",
		"tsdown": "^0.22.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.0",
		"vitest": "^4.1.7"
	},
	"peerDependencies": {
		"react": ">=19.1.0",
		"react-dom": ">=19.1.0"
	},
	"peerDependenciesMeta": {
		"react": {
			"optional": true
		},
		"react-dom": {
			"optional": true
		}
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/dan2dev/state-resource.git"
	},
	"bugs": {
		"url": "https://github.com/dan2dev/state-resource/issues"
	},
	"homepage": "https://github.com/dan2dev/state-resource#readme"
}
